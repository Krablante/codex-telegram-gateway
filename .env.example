# Runtime env template.
# On native Windows, copy this file to repo-local .env and fill the required values.
# On Linux services, prefer an env file outside the repo, for example
# ${XDG_CONFIG_HOME:-$HOME/.config}/codex-telegram-gateway/runtime.env.
# Linux repo-local .env fallback is ignored unless CODEX_GATEWAY_ALLOW_REPO_ENV=1
# is present in the shell environment before startup.
# For the full deployment matrix and service notes, see docs/deployment.md.

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_FORUM_CHAT_ID=
WORKSPACE_ROOT=
STATE_ROOT=
CURRENT_HOST_ID=

# Optional but useful.
DEFAULT_SESSION_BINDING_PATH=
TELEGRAM_EXPECTED_TOPICS=General
TELEGRAM_ALLOWED_BOT_IDS=
HOST_SYNC_INTERVAL_MINUTES=15
HOST_SSH_CONNECT_TIMEOUT_SECS=8
HOST_REGISTRY_PATH=
CODEX_ALLOW_SYSTEM_TEMP_DELIVERY=0

# Optional trusted bot ids for command routing.
SPIKE_BOT_ID=

# Optional Codex runtime overrides.
# Leave this empty to use the platform default: `codex` on Linux, `codex.cmd` on native Windows.
# If you need an explicit override on Windows, prefer `codex.cmd` or an absolute `...\codex.cmd` path.
CODEX_BIN_PATH=
CODEX_CONFIG_PATH=
# Default: exec-json. app-server is legacy debug only and also requires CODEX_ENABLE_LEGACY_APP_SERVER=1.
CODEX_GATEWAY_BACKEND=exec-json
CODEX_ENABLE_LEGACY_APP_SERVER=
CODEX_MODEL=
CODEX_REASONING_EFFORT=
CODEX_CONTEXT_WINDOW=
CODEX_AUTO_COMPACT_TOKEN_LIMIT=
MAX_PARALLEL_SESSIONS=10

# Optional Codex sessions/limits source.
# Raw Codex sessions root for gateway-host snapshot/context resolution. Defaults to that host's ~/.codex/sessions.
CODEX_SESSIONS_ROOT=
CODEX_LIMITS_SESSIONS_ROOT=
CODEX_LIMITS_COMMAND=
CODEX_LIMITS_CACHE_TTL_SECS=30
CODEX_LIMITS_COMMAND_TIMEOUT_SECS=15
