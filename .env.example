# Telegram bot from @BotFather
TELEGRAM_BOT_TOKEN=replace-me

# Required: numeric Telegram user id of the operator allowed to control the bot
TELEGRAM_ALLOWED_USER_ID=123456789

# Optional: comma-separated allowlist if you want more than one human operator
# TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# Optional: other trusted Telegram bot ids allowed to post into the same forum
# TELEGRAM_ALLOWED_BOT_IDS=222333444

# Required: numeric chat id of the Telegram forum-enabled supergroup
TELEGRAM_FORUM_CHAT_ID=-1001234567890

# Optional: comma-separated topic names that `make doctor` should expect
TELEGRAM_EXPECTED_TOPICS=General,Inbox,Ops

# Required: preferred workspace root for relative /new cwd=... bindings
# ATLAS_WORKSPACE_ROOT is still accepted as a compatibility alias.
# Windows example: O:/workspace
WORKSPACE_ROOT=/absolute/path/to/your/workspace

# Optional: default binding used when a new topic is created without an explicit cwd=
# If you want `/new Some Topic` to land in one main repo, point this there.
DEFAULT_SESSION_BINDING_PATH=/absolute/path/to/your/workspace

# Optional runtime overrides
# STATE_ROOT=/home/you/.local/state/codex-telegram-gateway
# CODEX_CONFIG_PATH=/home/you/.codex/config.toml
# CODEX_SESSIONS_ROOT=/home/you/.codex/sessions
# On native Windows, install Codex CLI first with scripts\windows\install-codex.cmd
CODEX_BIN_PATH=codex
MAX_PARALLEL_SESSIONS=10

# Optional Omni supervisor for /auto
# Leave these unset if you want a simpler Spike-only deployment.
# OMNI_ENABLED=false
# OMNI_BOT_TOKEN=replace-me
# OMNI_BOT_ID=555666777
# SPIKE_BOT_ID=111222333
