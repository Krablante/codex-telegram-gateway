{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "lib": ["ES2022"],
    "maxNodeModuleJsDepth": 0,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2022"
  },
  "include": [
    "src/**/*.js",
    "scripts/**/*.mjs",
    "test/**/*.js",
    "test-support/**/*.js"
  ]
}
